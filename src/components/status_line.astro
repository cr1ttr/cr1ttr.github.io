
<style>
    .status-line {
        display: flex;
        flex-direction: column;
        position: fixed;
        bottom: 0rem;
        left: 0;
        right: 0;
    }

    .status-line__sub-container {
        height: 1.5rem;
        background-color: var(--gray-2);
    }

    .status-line__main-container {
        display: flex;
        flex-direction: row;
        height: 1.5rem;
        width: 100%;
        background-color: var(--gray-2);
        align-items: center;
    }

    .status-line__mode {
        background-color: var(--yellow-11);
        color: var(--yellow-4);
        padding: 0.1rem 0.75rem;
        font-weight: 800;
        height: 100%;
    }

    .status-line__mode-flair {
        width: 0.75rem;
        align-self: stretch;
        clip-path: polygon(0 0, 100% 50%, 0 100%);
        background-color: var(--yellow-11);
    }

    .status-line__mode-flair--reversed {
        clip-path: polygon(0 50%, 100% 0, 100% 100%);
    }

    .status-line__file {
        padding-left: 1rem;
    }

    @keyframes glow {
        0%, 100% {
            text-shadow: 0 0 4px currentColor;
        }
        50% {
            text-shadow: 0 0 2px white, 0 0 6px navajowhite;
        }
    }

    .glow-text {
        animation: glow 2s ease-in-out infinite;
    }

    .status-line__spacer {
        flex-grow: 1;
    }


    /*
        width of 11 characters to support 0000:0000 format and prevent dynamic resizing


    */

    .status-line__file-type {
        margin-right: 1rem;
    }

    .status-line__utf-8 {
        margin-right: 1rem;
    }

    .status-line__cursor-pos {
        width: 9ch;
        text-align: center;
        box-sizing: content-box;
        background-color: var(--yellow-11);
        padding: 0 0.5rem;
        color: var(--yellow-4);
        font-weight: bold;
        height: 100%;
    }

    @media (max-width: 575px) {
        .status-line__file {
            display: none;
        }
    }

    @media (max-width: 350px) {
        .status-line__cursor-pos,
        .status-line__file-type,
        .status-line__mode-flair--reversed,
        .status-line__utf-8 {
            display: none;
        }
    }
</style>

<div class="status-line">
    <div class="status-line__main-container">
        <div class="status-line__mode">NORMAL</div>
        <div class="status-line__mode-flair"></div>
        <div class="status-line__file">crittr.github.io{Astro.url.pathname}</div>
        <div class="status-line__spacer"></div>
        <div class="status-line__file-type">HTML</div>
        <div class="status-line__utf-8">utf-8</div>
        <div class="status-line__mode-flair status-line__mode-flair--reversed"></div>
        <div class="status-line__cursor-pos">?:?</div>
    </div>
    <div class="status-line__sub-container"/>
</div>

<!-- have a working nvim command system -->
<script>
  const element = document.querySelector(".status-line__cursor-pos");
  document.addEventListener("mousemove", (event) => {
    if (element) {
      element.textContent = `${event.clientX}:${event.clientY}`;
    }
  });
</script>
