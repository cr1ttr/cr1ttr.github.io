    <a href="https://bsky.app/profile/cr1ttr.bsky.social"><FaIcon iconType="brands" name="bluesky"/></a>
    <a href="https://discord.gg/FsHRDs9HaT"><FaIcon iconType="brands" name="discord"/></a>

</div>


</DefaultLayout>
